{
  "name": "folder-graph-organizer",
  "version": "1.0.0",
  "description": "Automatically creates folder index notes and links all notes to them, creating clean folder-cluster bubbles in Obsidian's graph view.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": ["obsidian", "obsidian-plugin", "graph-view"],
  "author": "Jacob",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@typescript-eslint/eslint-plugin": "5.29.0",
    "@typescript-eslint/parser": "5.29.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  }
}
